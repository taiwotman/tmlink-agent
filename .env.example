# ── n8n Editor Login ───────────────────────────────────────
# Credentials to use when completing the one-time n8n setup wizard
# at http://localhost:5678.
N8N_USER_EMAIL=you@mail.com
N8N_USER_PASSWORD=change-me

# ── Your email (used to log in to TMLink) ────────────────────
TMLINK_EMAIL=you@mail.com
APPROVER_EMAIL=you@mail.com
SMTP_FROM=you@mail.com

# ── Gmail App Password (required for TMLink OTP emails) ──────
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=replace-with-app-password

# ── Internal URLs (do not change) ────────────────────────────
TMLINK_API_URL=http://tmlink-official:8000
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=UTC
N8N_BASE=/n8n/webhook
TMLINK_API_BASE=http://localhost:3001/tmlink-api
